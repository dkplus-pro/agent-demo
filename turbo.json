{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "unpackage/dist/**"]
    },
    "build:mp-weixin": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "unpackage/dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "dev:mp-weixin": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "gen": {
      "cache": false,
      "outputs": []
    }
  }
}
