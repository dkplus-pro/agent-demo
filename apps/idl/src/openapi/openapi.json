{
  "openapi": "3.1.0",
  "info": {
    "title": "Agent MVP API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Read server health",
        "responses": {
          "200": {
            "description": "Server health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/plugins": {
      "get": {
        "operationId": "listAgentPlugins",
        "summary": "List available agent plugins",
        "responses": {
          "200": {
            "description": "Available plugins",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentPluginListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/runs": {
      "post": {
        "operationId": "createAgentRun",
        "summary": "Create an agent run",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentRunRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent run result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentRunResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiErrorResponse": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": ["ok", "service"],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "AgentPluginManifest": {
        "type": "object",
        "required": ["name", "description", "capabilities"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "enabled": {
            "type": "boolean"
          },
          "inputSchema": {
            "$ref": "#/components/schemas/AgentPluginInputSchema"
          },
          "defaultConfig": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "AgentPluginInputSchema": {
        "type": "object",
        "required": ["minLength"],
        "properties": {
          "minLength": {
            "type": "integer"
          },
          "maxLength": {
            "type": "integer"
          },
          "requiredMetadataKeys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AgentPluginListResponse": {
        "type": "object",
        "required": ["plugins"],
        "properties": {
          "plugins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentPluginManifest"
            }
          }
        }
      },
      "AgentRunRequest": {
        "type": "object",
        "required": ["input"],
        "properties": {
          "input": {
            "type": "string",
            "minLength": 1
          },
          "pluginNames": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "pluginConfigs": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "AgentTraceEvent": {
        "type": "object",
        "required": ["id", "type", "message", "timestamp"],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["run.started", "plugin.started", "plugin.completed", "run.completed", "run.failed"]
          },
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "pluginName": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "durationMs": {
            "type": "number"
          }
        }
      },
      "AgentRunResponse": {
        "type": "object",
        "required": ["runId", "output", "events"],
        "properties": {
          "runId": {
            "type": "string"
          },
          "output": {
            "type": "string"
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentTraceEvent"
            }
          }
        }
      }
    }
  }
}
