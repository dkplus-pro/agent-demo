{
  "openapi": "3.1.0",
  "info": {
    "title": "Agent MVP API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Read server health",
        "responses": {
          "200": {
            "description": "Server health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/plugins": {
      "get": {
        "operationId": "listAgentPlugins",
        "summary": "List available agent plugins",
        "responses": {
          "200": {
            "description": "Available plugins",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentPluginListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/runs": {
      "post": {
        "operationId": "createAgentRun",
        "summary": "Create an agent run",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentRunRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent run result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentRunResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversations": {
      "get": {
        "operationId": "listConversations",
        "summary": "List conversations",
        "responses": {
          "200": {
            "description": "Conversation list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createConversation",
        "summary": "Create a conversation",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateConversationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created conversation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationDetailResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversations/{conversationId}": {
      "get": {
        "operationId": "getConversation",
        "summary": "Get a conversation",
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversation detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationDetailResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteConversation",
        "summary": "Delete a conversation",
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Delete result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteConversationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversations/{conversationId}/messages": {
      "get": {
        "operationId": "listConversationMessages",
        "summary": "List conversation messages",
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversation messages",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationMessagesResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiErrorResponse": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": ["ok", "service"],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "AgentPluginManifest": {
        "type": "object",
        "required": ["name", "description", "capabilities"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "enabled": {
            "type": "boolean"
          },
          "inputSchema": {
            "$ref": "#/components/schemas/AgentPluginInputSchema"
          },
          "defaultConfig": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "AgentPluginInputSchema": {
        "type": "object",
        "required": ["minLength"],
        "properties": {
          "minLength": {
            "type": "integer"
          },
          "maxLength": {
            "type": "integer"
          },
          "requiredMetadataKeys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AgentPluginListResponse": {
        "type": "object",
        "required": ["plugins"],
        "properties": {
          "plugins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentPluginManifest"
            }
          }
        }
      },
      "AgentRunRequest": {
        "type": "object",
        "required": ["input"],
        "properties": {
          "conversationId": {
            "type": "string"
          },
          "input": {
            "type": "string",
            "minLength": 1
          },
          "pluginNames": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "pluginConfigs": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "AgentTraceEvent": {
        "type": "object",
        "required": ["id", "type", "message", "timestamp"],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["run.started", "plugin.started", "plugin.completed", "llm.delta", "run.completed", "run.failed"]
          },
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "pluginName": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "durationMs": {
            "type": "number"
          }
        }
      },
      "AgentRunResponse": {
        "type": "object",
        "required": ["runId", "conversationId", "output", "events"],
        "properties": {
          "runId": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          },
          "output": {
            "type": "string"
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentTraceEvent"
            }
          }
        }
      },
      "ConversationSummary": {
        "type": "object",
        "required": ["id", "title", "createdAt", "updatedAt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "ConversationMessage": {
        "type": "object",
        "required": ["id", "conversationId", "role", "content", "createdAt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["user", "assistant", "system", "tool"]
          },
          "content": {
            "type": "string"
          },
          "runId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        }
      },
      "StoredAgentRun": {
        "type": "object",
        "required": ["id", "conversationId", "input", "output", "status", "events", "createdAt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          },
          "input": {
            "type": "string"
          },
          "output": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["running", "completed", "failed"]
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentTraceEvent"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "completedAt": {
            "type": "string"
          }
        }
      },
      "CreateConversationRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          }
        }
      },
      "ConversationListResponse": {
        "type": "object",
        "required": ["conversations"],
        "properties": {
          "conversations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConversationSummary"
            }
          }
        }
      },
      "ConversationDetailResponse": {
        "type": "object",
        "required": ["conversation", "messages", "runs"],
        "properties": {
          "conversation": {
            "$ref": "#/components/schemas/ConversationSummary"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConversationMessage"
            }
          },
          "runs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StoredAgentRun"
            }
          }
        }
      },
      "ConversationMessagesResponse": {
        "type": "object",
        "required": ["messages"],
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConversationMessage"
            }
          }
        }
      },
      "DeleteConversationResponse": {
        "type": "object",
        "required": ["ok"],
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
